.selector,
.form-card,
.manage-item {
  margin-bottom: 24rpx;
}

.selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 112rpx;
  border-color: #b9d7e2;
  background: #eef6f8;
}

.selector-content {
  flex: 1;
  min-width: 0;
}

.selector-label {
  color: #526c77;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.4;
}

.selector-value {
  margin-top: 6rpx;
  color: #183f4f;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.selector-action {
  display: flex;
  flex: none;
  align-items: center;
  margin-left: 20rpx;
  color: #24566a;
}

.selector-hint {
  font-size: 30rpx;
  font-weight: 700;
}

.selector-arrow {
  margin-left: 10rpx;
  font-size: 40rpx;
  line-height: 1;
}

.panel-title {
  margin-bottom: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border: 2rpx solid #d5e4e9;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 32rpx;
}

.input {
  min-height: 88rpx;
}

.textarea {
  min-height: 180rpx;
  padding-top: 20rpx;
  line-height: 1.6;
}

.media-section {
  margin-bottom: 24rpx;
  padding: 22rpx;
  border: 2rpx solid #d5e4e9;
  border-radius: 12rpx;
  background: #f6fafb;
}

.field-label {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.media-item {
  width: calc((100% - 18rpx) / 2);
}

.media-image {
  width: 100%;
  height: 220rpx;
  border-radius: 10rpx;
  background: #e5eef1;
}

.media-video {
  width: 100%;
  border-radius: 10rpx;
}

.upload-button,
.media-remove {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 10rpx;
  font-size: 30rpx;
}

.upload-button {
  border: 2rpx solid #24566a;
  background: #ffffff;
  color: #24566a;
  font-weight: 700;
}

.media-remove {
  margin-top: 10rpx;
  background: #fff0ee;
  color: #b42318;
}

.video-remove {
  width: 100%;
}

.upload-progress {
  margin-bottom: 20rpx;
  color: #24566a;
  font-size: 30rpx;
  line-height: 1.5;
}

.form-actions,
.row-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.save,
.secondary {
  flex: 1;
}

.secondary {
  background: #46515a;
}

.item-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.5;
}

.item-desc {
  margin-top: 10rpx;
  color: #5f6c72;
  font-size: 32rpx;
  line-height: 1.5;
}

.admin-course-id {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border: 2rpx solid #b9d7e2;
  border-radius: 14rpx;
  background: #eef6f8;
}

.admin-course-id-label {
  color: #526c77;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.admin-course-id-value {
  margin-top: 8rpx;
  color: #24566a;
  font-family: monospace;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.5;
  overflow-wrap: anywhere;
  word-break: break-all;
}

.small-button {
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 12rpx;
  background: #24566a;
  color: #ffffff;
  font-size: 32rpx;
  line-height: 88rpx;
}

.small-button::after,
.upload-button::after,
.media-remove::after {
  border: 0;
}

.edit-button {
  border: 2rpx solid #24566a;
  background: #ffffff;
  color: #24566a;
}

.danger {
  background: #a9342a;
}

.status-button {
  display: inline-flex;
  align-items: center;
  margin-top: 20rpx;
}
