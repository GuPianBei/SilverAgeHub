.selector,
.form-card,
.manage-item {
  margin-bottom: 24rpx;
}

.selector {
  font-size: 34rpx;
  font-weight: 700;
}

.panel-title {
  margin-bottom: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  padding: 0 24rpx;
  border: 2rpx solid #d8dfd8;
  border-radius: 12rpx;
  background: #ffffff;
  font-size: 32rpx;
}

.input {
  min-height: 88rpx;
}

.textarea {
  min-height: 180rpx;
  padding-top: 20rpx;
  line-height: 1.6;
}

.form-actions,
.row-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.save,
.secondary {
  flex: 1;
}

.secondary {
  background: #46515a;
}

.item-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.5;
}

.item-desc {
  margin-top: 10rpx;
  color: #5f6c72;
  font-size: 32rpx;
  line-height: 1.5;
}

.small-button {
  min-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 12rpx;
  background: #1f7a5a;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 76rpx;
}

.danger {
  background: #b42318;
}

.status-button {
  display: inline-flex;
  align-items: center;
  margin-top: 20rpx;
}
