<view class="page">
  <view class="section">
    <view class="title">管理端</view>
    <view class="subtitle">助教和运营人员维护教程、课程与预约。</view>
  </view>

  <view wx:if="{{adminOpenid && !isAdmin}}" class="card state error">
    当前账号还不是管理员。请在云数据库 admin_user 集合中新增一条记录，
    将 openid 设为下面的值，并将 enabled 设为 true：
    {{adminOpenid}}
  </view>

  <picker wx:if="{{isAdmin}}" mode="selector" range="{{resources}}" range-key="label" value="{{resourceIndex}}" bindchange="onResourceChange">
    <view class="card selector">
      <view class="selector-content">
        <view class="selector-label">当前管理内容</view>
        <view class="selector-value">{{resourceLabel}}</view>
      </view>
      <view class="selector-action">
        <view class="selector-hint">点击切换</view>
        <view class="selector-arrow">⌄</view>
      </view>
    </view>
  </picker>

  <view wx:if="{{isAdmin && resource !== 'order'}}" class="card form-card">
    <view class="panel-title">{{editingId ? '编辑内容' : '新增内容'}}</view>

    <input class="input" placeholder="标题" value="{{form.title}}" data-field="title" bindinput="onInput" />

    <block wx:if="{{resource === 'guide'}}">
      <input class="input" placeholder="分类" value="{{form.category}}" data-field="category" bindinput="onInput" />
      <textarea class="textarea" placeholder="教程内容" value="{{form.content}}" data-field="content" bindinput="onInput" />

      <view class="media-section">
        <view class="field-label">教程图片（最多 {{maxGuideImages}} 张，第一张作为封面）</view>
        <view wx:if="{{form.images.length}}" class="media-grid">
          <view wx:for="{{form.images}}" wx:key="*this" class="media-item">
            <image class="media-image" src="{{item}}" mode="aspectFill" data-src="{{item}}" bindtap="previewGuideImage" />
            <button class="media-remove" data-index="{{index}}" bindtap="removeGuideImage">移除</button>
          </view>
        </view>
        <button
          class="upload-button"
          loading="{{uploadingImages}}"
          disabled="{{uploadingImages || uploadingVideo || form.images.length >= maxGuideImages}}"
          bindtap="chooseGuideImages"
        >
          {{form.images.length ? '继续添加图片' : '选择并上传图片'}}
        </button>
      </view>

      <view class="media-section">
        <view class="field-label">教程视频（最多 1 个）</view>
        <view wx:if="{{form.video}}" class="video-preview">
          <video class="media-video" src="{{form.video}}" controls></video>
          <button class="media-remove video-remove" bindtap="removeGuideVideo">移除视频</button>
        </view>
        <button
          wx:else
          class="upload-button"
          loading="{{uploadingVideo}}"
          disabled="{{uploadingImages || uploadingVideo}}"
          bindtap="chooseGuideVideo"
        >
          选择并上传视频
        </button>
      </view>

      <view wx:if="{{uploadProgress}}" class="upload-progress">{{uploadProgress}}</view>
    </block>

    <block wx:if="{{resource === 'course'}}">
      <textarea class="textarea" placeholder="课程介绍" value="{{form.description}}" data-field="description" bindinput="onInput" />
      <input class="input" placeholder="上课时间，如 2026-07-01 09:30" value="{{form.time}}" data-field="time" bindinput="onInput" />
      <input class="input" placeholder="上课地点" value="{{form.location}}" data-field="location" bindinput="onInput" />
      <input class="input" placeholder="人数上限" type="number" value="{{form.limitCount}}" data-field="limitCount" bindinput="onInput" />
    </block>

    <view class="form-actions">
      <button class="button save" loading="{{saving}}" disabled="{{saving || uploadingImages || uploadingVideo}}" bindtap="saveForm">保存</button>
      <button class="button secondary" disabled="{{uploadingImages || uploadingVideo}}" bindtap="startCreate">清空</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="card state">正在加载管理数据...</view>
  <view wx:elif="{{error}}" class="card state error">{{error}}</view>

  <block wx:elif="{{isAdmin}}">
    <block wx:if="{{resource === 'guide'}}">
      <view wx:for="{{list}}" wx:key="_id" class="card manage-item">
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.category}}</view>
        <view class="row-actions">
          <button class="small-button edit-button" data-item="{{item}}" bindtap="startEdit">编辑</button>
          <button class="small-button danger" data-id="{{item._id}}" bindtap="deleteItem">删除</button>
        </view>
      </view>
    </block>

    <block wx:if="{{resource === 'course'}}">
      <view wx:for="{{list}}" wx:key="_id" class="card manage-item">
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.time}}</view>
        <view class="item-desc">{{item.location}} · {{item.limitCount}} 人</view>
        <view class="row-actions">
          <button class="small-button edit-button" data-item="{{item}}" bindtap="startEdit">编辑</button>
          <button class="small-button danger" data-id="{{item._id}}" bindtap="deleteItem">删除</button>
        </view>
      </view>
    </block>

    <block wx:if="{{resource === 'order'}}">
      <view wx:for="{{list}}" wx:key="_id" class="card manage-item">
        <view class="item-title">{{item.userName}}</view>
        <view class="item-desc">电话：{{item.phone}}</view>
        <view class="admin-course-id">
          <view class="admin-course-id-label">课程编号</view>
          <view class="admin-course-id-value">{{item.courseId}}</view>
        </view>
        <view class="item-desc">状态：{{item.status}}</view>
        <picker mode="selector" range="{{statusOptions}}" data-id="{{item._id}}" bindchange="onStatusChange">
          <view class="small-button status-button">更新状态</view>
        </picker>
      </view>
    </block>

    <view wx:if="{{list.length === 0}}" class="card state">暂无数据</view>
  </block>
</view>
