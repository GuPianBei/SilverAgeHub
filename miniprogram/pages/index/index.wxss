.home-page {
  padding-top: 24rpx;
}

.news-swiper {
  height: 340rpx;
  overflow: hidden;
  border-radius: 30rpx;
}

.hero-banner {
  position: relative;
  display: flex;
  box-sizing: border-box;
  height: 340rpx;
  overflow: hidden;
  padding: 36rpx 32rpx;
  border: 2rpx solid #bad9e5;
  border-radius: 30rpx;
  background: #dceef5;
  box-shadow: 0 12rpx 32rpx rgba(36, 86, 106, 0.14);
}

.hero-banner::before {
  position: absolute;
  right: -100rpx;
  bottom: -140rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.42);
  content: "";
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 64%;
}

.hero-kicker {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border: 2rpx solid #79bfd8;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.48);
  color: #24566a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-title {
  margin-top: 24rpx;
  color: #183f4f;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.35;
}

.hero-desc {
  margin-top: 18rpx;
  color: #426778;
  font-size: 30rpx;
  line-height: 1.6;
}

.hero-note {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #426778;
  font-size: 28rpx;
  line-height: 1.4;
}

.hero-logo-wrap {
  position: absolute;
  right: 22rpx;
  bottom: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 210rpx;
  height: 210rpx;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  background: #f7f2e8;
  box-shadow: 0 12rpx 28rpx rgba(38, 92, 113, 0.2);
}

.hero-logo {
  width: 100%;
  height: 100%;
}

.quick-actions {
  display: flex;
  justify-content: space-between;
  margin: 28rpx 0 40rpx;
  padding: 28rpx 18rpx;
  border: 2rpx solid #d5e4e9;
  border-radius: 24rpx;
  background: #ffffff;
}

.quick-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  min-width: 0;
  padding: 4rpx 8rpx;
}

.quick-item + .quick-item {
  border-left: 2rpx solid #e5eef1;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.icon-guide {
  background: #438eaa;
}

.icon-course {
  background: #d99a5b;
}

.icon-order {
  background: #24566a;
}

.quick-label {
  margin-top: 14rpx;
  color: #183f4f;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.content-section {
  margin-bottom: 24rpx;
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.section-heading > view {
  flex: 1;
  min-width: 0;
}

.section-more {
  display: flex;
  flex: none;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  min-height: 76rpx;
  padding: 0 20rpx;
  border: 2rpx solid #79bfd8;
  border-radius: 999rpx;
  color: #24566a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-title {
  color: #183f4f;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.35;
}

.section-desc {
  margin-top: 8rpx;
  color: #526c77;
  font-size: 30rpx;
  line-height: 1.5;
}

.recommend-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  align-items: start;
  padding-bottom: 28rpx;
}

.recommend-card {
  position: relative;
  overflow: hidden;
  border: 2rpx solid #d5e4e9;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(36, 86, 106, 0.08);
}

.recommend-card-offset {
  margin-top: 28rpx;
}

.recommend-index {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  z-index: 4;
  color: rgba(36, 86, 106, 0.32);
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.recommend-content {
  position: relative;
  z-index: 2;
  box-sizing: border-box;
  padding: 22rpx 20rpx 24rpx;
}

.recommend-meta {
  display: flex;
  align-items: center;
}

.recommend-tag {
  display: inline-flex;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #24566a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.recommend-title {
  min-height: 96rpx;
  margin-top: 16rpx;
  color: #183f4f;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.recommend-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid #e5eef1;
  color: #24566a;
  font-size: 30rpx;
  font-weight: 700;
}

.recommend-visual {
  position: relative;
  height: 236rpx;
  overflow: hidden;
  background: #dceef5;
}

.recommend-cover {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
}

.recommend-visual::before,
.recommend-visual::after {
  position: absolute;
  border-radius: 50%;
  content: "";
}

.recommend-visual::before {
  top: -44rpx;
  right: -30rpx;
  width: 150rpx;
  height: 150rpx;
  background: rgba(55, 132, 166, 0.16);
}

.recommend-visual::after {
  bottom: -64rpx;
  left: -44rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.68);
}

.visual-path {
  position: absolute;
  top: 30rpx;
  right: 24rpx;
  left: 24rpx;
  height: 126rpx;
}

.visual-step {
  position: absolute;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border: 5rpx solid #ffffff;
  border-radius: 50%;
  background: #438eaa;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.step-one {
  top: 0;
  left: 0;
}

.step-two {
  top: 58rpx;
  left: 50%;
  transform: translateX(-50%);
}

.step-three {
  top: 4rpx;
  right: 0;
}

.visual-line {
  position: absolute;
  top: 64rpx;
  left: 20rpx;
  width: calc(100% - 40rpx);
  height: 8rpx;
  border-radius: 999rpx;
  background: #79bfd8;
  transform: rotate(2deg);
}

.lesson-sheet {
  position: absolute;
  bottom: 18rpx;
  left: 50%;
  z-index: 2;
  box-sizing: border-box;
  width: 154rpx;
  padding: 14rpx;
  border: 4rpx solid #ffffff;
  border-radius: 16rpx;
  background: #f7f2e8;
  box-shadow: 0 8rpx 18rpx rgba(36, 86, 106, 0.14);
  transform: translateX(-50%);
}

.lesson-sheet-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border-radius: 14rpx;
  background: #d99a5b;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.lesson-sheet-lines {
  margin-top: 14rpx;
}

.lesson-sheet-lines view {
  width: 100%;
  height: 7rpx;
  margin-top: 9rpx;
  border-radius: 999rpx;
  background: #b6d2dc;
}

.lesson-sheet-lines view:last-child {
  width: 62%;
}

.feature-arrow {
  font-size: 44rpx;
  font-weight: 400;
  line-height: 1;
}
