<view class="page">
  <view class="section">
    <view class="title">提交预约</view>
    <view class="subtitle">请填写联系信息，工作人员会处理报名。</view>
  </view>

  <view class="card form">
    <view class="field">
      <view class="field-label">姓名</view>
      <input class="input" placeholder="请输入预约人姓名" value="{{userName}}" bindinput="onUserNameInput" />
    </view>
    <view class="field">
      <view class="field-label">联系电话</view>
      <input class="input" placeholder="请输入手机号码" type="number" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <button class="button submit" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">提交报名</button>
  </view>
</view>
