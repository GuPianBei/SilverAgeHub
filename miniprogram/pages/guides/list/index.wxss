.item {
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
  padding: 0;
}

.item::before {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  z-index: 2;
  height: 8rpx;
  background: #79bfd8;
  content: "";
}

.cover-image,
.cover-placeholder {
  width: 100%;
  height: 280rpx;
}

.cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #dceef5;
  color: #526c77;
  font-size: 32rpx;
}

.item-content {
  padding: 28rpx 30rpx 30rpx;
}

.item-category {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #dceef5;
  color: #24566a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.item-title {
  margin-top: 18rpx;
  color: #183f4f;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.45;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 2rpx solid #e5eef1;
}

.item-hint {
  color: #526c77;
  font-size: 30rpx;
  line-height: 1.5;
}

.item-arrow {
  color: #24566a;
  font-size: 48rpx;
  line-height: 1;
}
