.article {
  position: relative;
  overflow: hidden;
  padding: 36rpx 32rpx 40rpx;
  border-top: 10rpx solid #79bfd8;
}

.article-category {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #dceef5;
  color: #24566a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.article-title {
  margin-top: 20rpx;
}

.article-divider {
  height: 2rpx;
  margin: 28rpx 0;
  background: #d5e4e9;
}

.content-label {
  color: #24566a;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.5;
}

.content {
  margin-top: 16rpx;
  color: #183f4f;
  font-size: 34rpx;
  line-height: 1.8;
  white-space: pre-wrap;
}

.guide-image,
.guide-video {
  width: 100%;
  box-sizing: border-box;
  margin-top: 32rpx;
  border: 2rpx solid #d5e4e9;
  border-radius: 16rpx;
  background: #eef6f8;
}
