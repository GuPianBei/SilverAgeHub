<view class="page">
  <view wx:if="{{loading}}" class="card state">正在加载教程...</view>
  <view wx:elif="{{error}}" class="card state error">{{error}}</view>

  <view wx:else class="card">
    <view class="title">{{guide.title}}</view>
    <view class="subtitle">{{guide.category}}</view>
    <view class="content">{{guide.content}}</view>

    <block wx:if="{{guide.images && guide.images.length}}">
      <image wx:for="{{guide.images}}" wx:key="*this" class="guide-image" src="{{item}}" mode="widthFix" />
    </block>

    <video wx:if="{{guide.video}}" class="guide-video" src="{{guide.video}}" controls></video>
  </view>
</view>
