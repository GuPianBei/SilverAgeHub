<view class="page">
  <view class="section">
    <view class="title">我的预约</view>
    <view class="subtitle">查看已经提交的课程预约。</view>
  </view>

  <view wx:if="{{loading}}" class="card state">正在加载预约...</view>
  <view wx:elif="{{error}}" class="card state error">{{error}}</view>

  <block wx:else>
    <block wx:for="{{orders}}" wx:key="_id">
      <view class="card item">
        <view class="item-head">
          <view class="item-title">{{item.courseTitle}}</view>
          <view class="status-badge {{item.statusText === '已确认' ? 'status-confirmed' : item.statusText === '完成' ? 'status-done' : 'status-pending'}}">
            {{item.statusText}}
          </view>
        </view>
        <view class="item-info">
          <view class="info-row">
            <view class="info-label">预约人</view>
            <view class="info-value">{{item.userName}}</view>
          </view>
          <view class="info-row">
            <view class="info-label">上课时间</view>
            <view class="info-value">{{item.courseTime}}</view>
          </view>
          <view class="info-row">
            <view class="info-label">上课地点</view>
            <view class="info-value">{{item.courseLocation}}</view>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{orders.length === 0}}" class="card state">还没有预约记录。可前往“课程预约”选择课程。</view>
  </block>

  <view wx:if="{{enableAdminEntry}}" class="admin-entry" bindtap="openAdmin">
    进入运营管理
  </view>
</view>
