<view class="page">
  <view class="section">
    <view class="title">我的预约</view>
    <view class="subtitle">查看已经提交的课程预约。</view>
  </view>

  <view wx:if="{{loading}}" class="card state">正在加载预约...</view>
  <view wx:elif="{{error}}" class="card state error">{{error}}</view>

  <block wx:else>
    <block wx:for="{{orders}}" wx:key="_id">
      <view class="card item">
        <view class="item-title">课程编号：{{item.courseId}}</view>
        <view class="item-desc">预约人：{{item.userName}}</view>
        <view class="item-desc">状态：{{item.statusText}}</view>
      </view>
    </block>
    <view wx:if="{{orders.length === 0}}" class="card state">暂无预约</view>
  </block>

  <view wx:if="{{enableAdminEntry}}" class="admin-entry" bindtap="openAdmin">
    进入运营管理
  </view>
</view>
