.item {
  position: relative;
  overflow: hidden;
  margin-bottom: 28rpx;
  padding: 32rpx 30rpx 26rpx;
}

.item::before {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  height: 8rpx;
  background: #d99a5b;
  content: "";
}

.item-title {
  color: #183f4f;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.45;
}

.item-meta {
  margin-top: 24rpx;
  padding: 6rpx 22rpx;
  border-radius: 14rpx;
  background: #eef6f8;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.meta-row + .meta-row {
  border-top: 2rpx solid #d5e4e9;
}

.meta-label {
  flex: none;
  width: 88rpx;
  color: #24566a;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.55;
}

.meta-value {
  flex: 1;
  min-width: 0;
  color: #183f4f;
  font-size: 32rpx;
  line-height: 1.55;
}

.item-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 64rpx;
  margin-top: 18rpx;
}

.item-hint {
  color: #526c77;
  font-size: 30rpx;
  line-height: 1.5;
}

.item-arrow {
  color: #24566a;
  font-size: 48rpx;
  line-height: 1;
}
