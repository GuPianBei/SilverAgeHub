page {
  min-height: 100vh;
  background: #f7f2e8;
  color: #183f4f;
  font-size: 32rpx;
}

.page {
  box-sizing: border-box;
  padding: 36rpx 32rpx 176rpx;
}

.section {
  position: relative;
  overflow: hidden;
  margin-bottom: 36rpx;
  padding: 30rpx;
  border: 2rpx solid #bad9e5;
  border-radius: 26rpx;
  background: #dceef5;
}

.section::after {
  position: absolute;
  top: -72rpx;
  right: -48rpx;
  width: 190rpx;
  height: 190rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  content: "";
}

.title {
  position: relative;
  z-index: 1;
  color: #183f4f;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  color: #526c77;
  font-size: 32rpx;
  line-height: 1.6;
}

.card {
  box-sizing: border-box;
  padding: 30rpx;
  border: 2rpx solid #d5e4e9;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(36, 86, 106, 0.07);
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border: 2rpx solid #24566a;
  border-radius: 16rpx;
  background: #24566a;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.button::after {
  border: 0;
}

.button[disabled] {
  border-color: #9aabb2;
  background: #9aabb2;
  color: #ffffff;
}

.state {
  padding: 40rpx 32rpx;
  color: #526c77;
  font-size: 32rpx;
  line-height: 1.6;
  text-align: center;
}

.error {
  border-color: #e7c4bf;
  background: #fff7f5;
  color: #a9342a;
}
