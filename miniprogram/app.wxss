page {
  min-height: 100vh;
  background: #f7f7f2;
  color: #1f2933;
  font-size: 32rpx;
}

.page {
  padding: 32rpx;
}

.section {
  margin-bottom: 32rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.35;
}

.subtitle {
  margin-top: 12rpx;
  color: #5f6c72;
  font-size: 30rpx;
  line-height: 1.6;
}

.card {
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.08);
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 12rpx;
  background: #1f7a5a;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.state {
  color: #5f6c72;
  font-size: 32rpx;
  line-height: 1.6;
}

.error {
  color: #b42318;
}
